# macOS / Windows desktop junk
.DS_Store
**/.DS_Store
desktop.ini
**/desktop.ini

# Raw developer material kept locally alongside the site.
# This repo is PUBLIC and serves listings.sandersalbania.com — inbound developer
# files (agreements, economic offers, unpriced brochures) must never be pushed to it.
Manisteri new batch/

# g8/ is a local staging folder for brochures + developer PDFs (A/B unit codes,
# ~60MB each) and the naming register. None of it is web content — ignore it whole.
g8/

# Brochure source PDFs (multi-MB marketing source, not web assets). Kept locally
# in the unit/g8 folders but never committed to the public site repo.
*_Sanders.pdf
**/*_Sanders.pdf

# Source spreadsheets (unit registers etc.) — working docs, not web assets.
*.xlsx
**/*.xlsx

# _work/ is the pipeline's build-scratch (per-unit config.json + raw assets like
# hero.jpg/g1.jpg). Never web content — the live files are /<slug>/index.html,
# /<slug>/thumb.jpg, units.json and gallery index.html. Ignore it whole.
_work/
